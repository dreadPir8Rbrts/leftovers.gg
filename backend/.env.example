# App database connection — use the Supabase connection pooler (PgBouncer) URL.
# Found in: Supabase dashboard → Project Settings → Database → Connection pooling → URI
# Example: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres

# Migration database connection — use the Supabase DIRECT connection URL (not the pooler).
# PgBouncer transaction mode cannot run DDL; Alembic must bypass it.
# Found in: Supabase dashboard → Project Settings → Database → Connection string → URI
# Example: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
MIGRATION_DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

REDIS_URL=redis://localhost:6379/0

# Scraper droplet Redis — used only to enqueue on-demand pricing scrape tasks.
# Format: redis://:<password>@<droplet-ip>:6379/0
# Leave unset to disable on-demand scraping (pricing API returns 202 without enqueueing).
SCRAPER_REDIS_URL=

# Google Cloud Vision — base64-encoded full service account JSON key file.
# Generate with: base64 -i your-key.json | tr -d '\n'
# Required for the Quick Scan (OCR) endpoint.
GOOGLE_CREDENTIALS_BASE64=

# Google Cloud Translation API key.
# Required only for running scripts/backfill_en_names.py (seed-time JA→EN translation).
# Create at: Google Cloud Console → APIs & Services → Credentials → API Key
# Restrict key to "Cloud Translation API" only.
GOOGLE_TRANSLATE_API_KEY=
